# DataBridge Configuration
# Copy this file to .env and fill in your values

PORT=3000

# ═══════════════ REQUIRED ═══════════════
# DeepSeek API Key (get from https://platform.deepseek.com)
# Recommended for China: no VPN, cheap, high quality Chinese
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ═══════════════ OPTIONAL ═══════════════
# JWT Secret (auto-generated if not set)
# JWT_SECRET=your-random-string-here

# ── Payment (Stripe) ──
# Get keys from https://dashboard.stripe.com/test
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email Verification (SMTP) ──
# QQ邮箱: host=smtp.qq.com port=587 secure=false
# Gmail: host=smtp.gmail.com port=587 secure=false (need app password)
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@qq.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@databridge.app

# ── Fallback ──
# OPENAI_API_KEY=sk-your-openai-key-here
# DEEPL_API_KEY=your-deepl-key-here
